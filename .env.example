PORT=3000
ADMIN_EMAIL=ozgur@example.com
FIREBASE_CONFIG_PATH=./firebase-service-account.json
FIREBASE_WEB_API_KEY=your_firebase_web_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_APP_ID=your-firebase-app-id

# AI Provider Keys
FAL_AI_KEY=your_fal_ai_key
REPLICATE_KEY=your_replicate_key
DEEPSEEK_KEY=your_deepseek_key
OPENROUTER_KEY=your_openrouter_key
GEMINI_KEY=your_gemini_key

# RevenueCat
REVENUECAT_API_KEY=your_revenuecat_key
REVENUECAT_PROJECT_ID=your_project_id

# Cloudflare R2 / S3 Storage
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_REGION=auto
S3_BUCKET_NAME=your-bucket
S3_PUBLIC_URL=https://cdn.yourdomain.com

# Rate Limiting
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW=60

# CORS (virgul ile ayrilmis origin listesi, varsayilan: *)
# CORS_ALLOW_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com
